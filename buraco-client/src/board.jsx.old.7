import React, { useState } from 'react';
import { sortCards, getCanastaStatus } from './game.js';

const Card = ({ card, isSelected, onClick }) => {
  const isRed = card.suit === '♥' || card.suit === '♦';
  return (
    <div 
      onClick={onClick}
      style={{
        border: isSelected ? '3px solid #ffd700' : '1px solid #333',
        transform: isSelected ? 'translateY(-10px)' : 'none',
        transition: 'all 0.2s', cursor: onClick ? 'pointer' : 'default',
        borderRadius: '8px', width: '60px', height: '90px',
        display: 'inline-flex', flexDirection: 'column',
        justifyContent: 'center', alignItems: 'center', margin: '2px',
        backgroundColor: 'white', color: isRed ? 'red' : 'black',
        boxShadow: '2px 2px 5px rgba(0,0,0,0.2)'
      }}>
      <div style={{ fontSize: '1.2em', fontWeight: 'bold' }}>{card.rank}</div>
      <div style={{ fontSize: '1.5em' }}>{card.suit}</div>
    </div>
  );
};

const CardBack = ({ label, count, onClick }) => (
  <div 
    onClick={onClick}
    style={{
      border: '2px solid white', borderRadius: '8px', width: '60px', height: '90px', margin: '2px',
      backgroundColor: '#0a3d62', backgroundImage: 'repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.1) 5px, rgba(255,255,255,0.1) 10px)',
      boxShadow: '2px 2px 5px rgba(0,0,0,0.5)', display: 'flex', flexDirection: 'column', 
      justifyContent: 'center', alignItems: 'center', color: 'white', 
      cursor: onClick ? 'pointer' : 'default', textAlign: 'center'
    }}>
    <span style={{ fontSize: '0.8em', fontWeight: 'bold' }}>{label}</span>
    <span style={{ fontSize: '1.2em' }}>{count}</span>
  </div>
);

export function BuracoBoard({ ctx, G, moves, playerID }) {
  const [selectedCards, setSelectedCards] = useState([]);
  const [localRules, setLocalRules] = useState({ discard: 'open', runners: 'none', largeCanasta: false });

  if (!G || !ctx) return <div style={{ color: 'white', padding: '50px' }}>Connecting...</div>;

  // RULE SETUP PHASE
  if (ctx.phase === 'rulesSetup') {
    if (playerID === '0') {
      return (
        <div style={{ padding: '50px', color: 'white', fontFamily: 'sans-serif', backgroundColor: '#1b4332', minHeight: '100vh' }}>
          <h2>Configure Game Rules</h2>
          <div style={{ marginBottom: '20px' }}>
            <label>Discard Pile Pickup: </label>
            <select value={localRules.discard} onChange={e => setLocalRules({...localRules, discard: e.target.value})}>
              <option value="open">Open (Always pick up)</option>
              <option value="closed">Closed (Must meld top card immediately)</option>
            </select>
          </div>
          <div style={{ marginBottom: '20px' }}>
            <label>Runners (Trincas) Allowed: </label>
            <select value={localRules.runners} onChange={e => setLocalRules({...localRules, runners: e.target.value})}>
              <option value="none">None</option>
              <option value="aces_threes">Aces & Threes</option>
              <option value="aces_kings">Aces & Kings</option>
              <option value="any">Any Rank</option>
            </select>
          </div>
          <div style={{ marginBottom: '20px' }}>
            <label>Large Canasta Bonus (A-K=500, A-A=1000): </label>
            <input type="checkbox" checked={localRules.largeCanasta} onChange={e => setLocalRules({...localRules, largeCanasta: e.target.checked})} />
          </div>
          <button onClick={() => moves.setRules(localRules)} style={{ padding: '10px 20px', cursor: 'pointer', background: '#ffd700', border: 'none', borderRadius: '5px', fontWeight: 'bold' }}>
            Start Game
          </button>
        </div>
      );
    } else {
      return <div style={{ color: 'white', padding: '50px', backgroundColor: '#1b4332', minHeight: '100vh' }}>Waiting for Host to set game rules...</div>;
    }
  }

  // GAME OVER OVERLAY
  if (ctx.gameover) {
    return (
      <div style={{ display: 'flex', flexDirection: 'column', justifyContent: 'center', alignItems: 'center', height: '100vh', backgroundColor: '#1b4332', color: 'white', fontFamily: 'sans-serif' }}>
        <h1 style={{ fontSize: '3em', color: '#ffd700' }}>Match Finished!</h1>
        <h2>Reason: {ctx.gameover.reason}</h2>
        <div style={{ display: 'flex', gap: '50px', marginTop: '40px' }}>
          <div style={{ background: 'rgba(0,0,0,0.5)', padding: '30px', borderRadius: '15px', textAlign: 'center', border: '2px solid #4da6ff' }}>
            <h2>Team 0</h2><p style={{ fontSize: '3em', fontWeight: 'bold' }}>{ctx.gameover.scores.team0}</p>
          </div>
          <div style={{ background: 'rgba(0,0,0,0.5)', padding: '30px', borderRadius: '15px', textAlign: 'center', border: '2px solid #ff4d4d' }}>
            <h2>Team 1</h2><p style={{ fontSize: '3em', fontWeight: 'bold' }}>{ctx.gameover.scores.team1}</p>
          </div>
        </div>
      </div>
    );
  }

  const rawHand = G.hands[playerID] || []; 
  // Separate the drawn card from the rest of the hand
  const standardHand = rawHand.filter(c => !c.isNewlyDrawn);
  const drawnCards = rawHand.filter(c => c.isNewlyDrawn);
  const sortedHand = sortCards(standardHand); 
  
  const topDiscard = G.discardPile[G.discardPile.length - 1];
  
  const myTeam = G.teams[playerID];
  const oppTeam = myTeam === 'team0' ? 'team1' : 'team0';
  
  const myTeamPlayers = G.teamPlayers[myTeam].filter(p => G.hands[p] !== undefined); // Only show active seats
  const oppTeamPlayers = G.teamPlayers[oppTeam].filter(p => G.hands[p] !== undefined);

  const toggleCardSelection = (cardId) => {
    setSelectedCards(prev => prev.includes(cardId) ? prev.filter(id => id !== cardId) : [...prev, cardId]);
  };

  const handleDiscardPileClick = () => {
    if (selectedCards.length === 1 && G.hasDrawn) {
      moves.discardCard(selectedCards[0]);
      setSelectedCards([]);
    } else if (!G.hasDrawn && G.discardPile.length > 0) {
      if (G.rules.discard === 'closed') {
        if (selectedCards.length >= 2) {
          moves.pickUpDiscard(selectedCards);
          setSelectedCards([]);
        } else {
          alert("Strict Rules: Select matching cards in your hand first to pick up the pile!");
        }
      } else {
        moves.pickUpDiscard();
      }
    }
  };

  const renderTeamTable = (teamPlayers, title, isMyTeam) => (
    <div style={{ background: isMyTeam ? 'rgba(77, 166, 255, 0.1)' : 'rgba(255, 77, 77, 0.1)', padding: '15px', borderRadius: '10px', height: '100%' }}>
      <h3 style={{ margin: '0 0 10px 0', color: isMyTeam ? '#4da6ff' : '#ff4d4d' }}>{title}</h3>
      <div style={{ display: 'flex', flexWrap: 'wrap', gap: '15px' }}>
        {teamPlayers.map(p => 
          (G.melds[p] || []).map((meldGroup, index) => {
            const status = getCanastaStatus(meldGroup, G.rules);
            let borderColor = status === 'clean' ? '#ffd700' : (status === 'dirty' ? '#c0c0c0' : 'transparent');
            return (
              <div 
                key={`${p}-${index}`} 
                onClick={() => { if (isMyTeam && selectedCards.length > 0) { moves.appendToMeld(p, index, selectedCards); setSelectedCards([]); } }}
                style={{ display: 'flex', background: 'rgba(0,0,0,0.3)', padding: '5px', borderRadius: '8px', border: `2px solid ${borderColor}`, cursor: (isMyTeam && selectedCards.length > 0) ? 'pointer' : 'default' }}
              >
                {meldGroup.map(card => <Card key={card.id} card={card} />)}
              </div>
            );
          })
        )}
        {isMyTeam && (
          <div 
            onClick={() => { if (selectedCards.length >= 3) { moves.playMeld(selectedCards); setSelectedCards([]); } }}
            style={{ border: '2px dashed #40916c', borderRadius: '8px', padding: '10px', display: 'flex', alignItems: 'center', cursor: selectedCards.length >= 3 ? 'pointer' : 'default', color: '#888' }}
          >
            + Place New Meld
          </div>
        )}
      </div>
    </div>
  );

  return (
    <div style={{ padding: '20px', fontFamily: 'sans-serif', backgroundColor: '#2d6a4f', minHeight: '100vh', color: 'white', display: 'flex', flexDirection: 'column', gap: '20px' }}>
      
      {/* ROW 1: System / Opponents */}
      <div style={{ display: 'flex', gap: '20px', minHeight: '200px' }}>
        <div style={{ display: 'flex', flexDirection: 'column', gap: '10px', width: '80px' }}>
          <CardBack label="Deck" count={G.deck.length} onClick={() => { if(!G.hasDrawn) moves.drawCard(); }} />
          <div onClick={handleDiscardPileClick} style={{ cursor: (!G.hasDrawn || (selectedCards.length === 1 && G.hasDrawn)) ? 'pointer' : 'not-allowed' }}>
            {topDiscard ? <Card card={topDiscard} /> : <div style={{ border: '2px dashed #40916c', width: '60px', height: '90px', borderRadius: '8px' }}></div>}
          </div>
        </div>
        <div style={{ flexGrow: 1 }}>{renderTeamTable(oppTeamPlayers, "Opponents' Table", false)}</div>
        <div style={{ display: 'flex', flexDirection: 'column', gap: '10px', width: '80px' }}>
          {G.pots.pot1.length > 0 ? <CardBack label="Pot" count={11} /> : <div style={{ width: '60px', height: '90px', border: '2px dashed #333' }}></div>}
          {G.pots.pot2.length > 0 ? <CardBack label="Pot" count={11} /> : <div style={{ width: '60px', height: '90px', border: '2px dashed #333' }}></div>}
        </div>
      </div>

      {/* ROW 2: Picked Up Card / My Team */}
      <div style={{ display: 'flex', gap: '20px', minHeight: '200px' }}>
        <div style={{ width: '80px', display: 'flex', flexDirection: 'column', alignItems: 'center' }}>
          <h4 style={{ margin: '0 0 5px 0', fontSize: '0.8em', color: '#ffd700' }}>Drawn</h4>
          {drawnCards.map(card => (
            <Card key={card.id} card={card} isSelected={selectedCards.includes(card.id)} onClick={() => toggleCardSelection(card.id)} />
          ))}
          {G.deck.length === 0 && G.hasDrawn && (
            <button onClick={() => moves.passTurn()} style={{ marginTop: '10px', background: '#ff4d4d', color: 'white', border: 'none', padding: '5px', borderRadius: '5px', cursor: 'pointer' }}>Pass</button>
          )}
        </div>
        <div style={{ flexGrow: 1 }}>{renderTeamTable(myTeamPlayers, "My Team's Table", true)}</div>
      </div>

      {/* ROW 3: Hand */}
      <div>
        <h2>My Hand {(!G.hasDrawn && ctx.currentPlayer === playerID) ? <span style={{ color: '#ff4d4d', fontSize: '0.6em' }}>(Must Draw)</span> : ""}</h2>
        <div style={{ display: 'flex', flexWrap: 'wrap' }}>
          {sortedHand.map(card => (
            <Card key={card.id} card={card} isSelected={selectedCards.includes(card.id)} onClick={() => toggleCardSelection(card.id)} />
          ))}
        </div>
      </div>

    </div>
  );
}
