import React, { useState } from 'react';

// Updated Card component to handle clicks and selection styling
const Card = ({ card, isSelected, onClick }) => {
  const isRed = card.suit === '♥' || card.suit === '♦';
  return (
    <div 
      onClick={onClick}
      style={{
        border: isSelected ? '3px solid #ffd700' : '1px solid #333',
        transform: isSelected ? 'translateY(-10px)' : 'none', // Pops the card up when selected
        transition: 'all 0.2s',
        cursor: 'pointer',
        borderRadius: '8px',
        width: '60px',
        height: '90px',
        display: 'inline-flex',
        flexDirection: 'column',
        justifyContent: 'center',
        alignItems: 'center',
        margin: '5px',
        backgroundColor: 'white',
        color: isRed ? 'red' : 'black',
        boxShadow: '2px 2px 5px rgba(0,0,0,0.2)'
      }}>
      <div style={{ fontSize: '1.2em', fontWeight: 'bold' }}>{card.rank}</div>
      <div style={{ fontSize: '1.5em' }}>{card.suit}</div>
    </div>
  );
};

export function BuracoBoard({ ctx, G, moves }) {
  // Local state to track which cards the player has clicked
  const [selectedCards, setSelectedCards] = useState([]);

  const myHand = G.hands[ctx.currentPlayer] || []; 
  const topDiscard = G.discardPile[G.discardPile.length - 1];
  const myMelds = G.melds[ctx.currentPlayer] || [];

  // Toggle selection on click
  const toggleCardSelection = (cardId) => {
    if (selectedCards.includes(cardId)) {
      setSelectedCards(selectedCards.filter(id => id !== cardId));
    } else {
      setSelectedCards([...selectedCards, cardId]);
    }
  };

  // Action Buttons
  const handlePlayMeld = () => {
    moves.playMeld(selectedCards);
    setSelectedCards([]); // Clear selection after playing
  };

  const handleDiscard = () => {
    if (selectedCards.length === 1) {
      moves.discardCard(selectedCards[0]);
      setSelectedCards([]); // Clear selection
    } else {
      alert("You can only discard exactly 1 card.");
    }
  };

  return (
    <div style={{ padding: '20px', fontFamily: 'sans-serif', backgroundColor: '#2d6a4f', minHeight: '100vh', color: 'white' }}>
      <h1>Player {ctx.currentPlayer}'s Turn</h1>
      
      {/* Table Area (Draw, Discard, and Melds) */}
      <div style={{ display: 'flex', gap: '40px', marginBottom: '20px' }}>
        
        {/* Draw & Discard */}
        <div style={{ display: 'flex', gap: '20px' }}>
          <div onClick={() => moves.drawCard()} style={{ cursor: 'pointer', textAlign: 'center' }}>
            <h3>Deck</h3>
            <div style={{ border: '2px dashed white', width: '60px', height: '90px', borderRadius: '8px', background: '#1b4332' }}></div>
          </div>

          <div style={{ textAlign: 'center' }}>
            <h3>Discard</h3>
            {topDiscard ? <Card card={topDiscard} /> : <div style={{ width: '60px', height: '90px' }}></div>}
          </div>
        </div>

        {/* Melds Area */}
        <div style={{ flexGrow: 1, paddingLeft: '20px', borderLeft: '2px solid #40916c' }}>
          <h3>Table Melds</h3>
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: '15px' }}>
            {myMelds.map((meldGroup, index) => (
              <div key={index} style={{ display: 'flex', background: 'rgba(0,0,0,0.2)', padding: '5px', borderRadius: '8px' }}>
                {meldGroup.map(card => (
                  <Card key={card.id} card={card} />
                ))}
              </div>
            ))}
          </div>
        </div>

      </div>

      <hr style={{ borderColor: '#40916c', margin: '30px 0' }} />

      {/* Action Buttons */}
      <div style={{ marginBottom: '15px' }}>
        <button 
          onClick={handlePlayMeld} 
          disabled={selectedCards.length < 3}
          style={{ padding: '10px', marginRight: '10px', cursor: 'pointer' }}>
          Lay Meld on Table (Needs 3+)
        </button>
        <button 
          onClick={handleDiscard} 
          disabled={selectedCards.length !== 1}
          style={{ padding: '10px', cursor: 'pointer' }}>
          Discard & End Turn
        </button>
      </div>

      {/* Player's Hand */}
      <h2>My Hand</h2>
      <div style={{ display: 'flex', flexWrap: 'wrap' }}>
        {myHand.map(card => (
          <Card 
            key={card.id} 
            card={card} 
            isSelected={selectedCards.includes(card.id)}
            onClick={() => toggleCardSelection(card.id)}
          />
        ))}
      </div>
    </div>
  );
}
