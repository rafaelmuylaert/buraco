import { Client } from 'boardgame.io/react';
import { SocketIO } from 'boardgame.io/multiplayer';
import { BuracoGame } from './game.js';
import { BuracoBoard } from './Board.jsx';

const BuracoClient = Client({
  game: BuracoGame,
  board: BuracoBoard,
  multiplayer: SocketIO({ server: 'http://10.0.0.2:8000' }), 
});

const App = () => (
  <div style={{ display: 'flex', flexDirection: 'column', gap: '50px', backgroundColor: '#111', padding: '20px' }}>
    {/* Top Board: Player 1 (Your Friend) */}
    <div style={{ border: '5px solid #ff4d4d', borderRadius: '15px', overflow: 'hidden' }}>
      <BuracoClient matchID="dev-room" playerID="1" />
    </div>

    {/* Bottom Board: Player 0 (You) */}
    <div style={{ border: '5px solid #4da6ff', borderRadius: '15px', overflow: 'hidden' }}>
      <BuracoClient matchID="dev-room" playerID="0" />
    </div>
  </div>
);

export default App;
