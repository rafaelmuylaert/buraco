import React, { useState } from 'react';
import { sortCards } from './game.js';

// Reusable Card Component
const Card = ({ card, isSelected, onClick }) => {
  const isRed = card.suit === '♥' || card.suit === '♦';
  return (
    <div 
      onClick={onClick}
      style={{
        border: isSelected ? '3px solid #ffd700' : '1px solid #333',
        transform: isSelected ? 'translateY(-10px)' : 'none',
        transition: 'all 0.2s',
        cursor: 'pointer',
        borderRadius: '8px',
        width: '60px', height: '90px',
        display: 'inline-flex', flexDirection: 'column',
        justifyContent: 'center', alignItems: 'center',
        margin: '2px', backgroundColor: 'white',
        color: isRed ? 'red' : 'black',
        boxShadow: '2px 2px 5px rgba(0,0,0,0.2)'
      }}>
      <div style={{ fontSize: '1.2em', fontWeight: 'bold' }}>{card.rank}</div>
      <div style={{ fontSize: '1.5em' }}>{card.suit}</div>
    </div>
  );
};

export function BuracoBoard({ ctx, G, moves, playerID }) {
  // Safety check for backend connection
  if (!G || !ctx) {
    return (
      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', height: '100vh', backgroundColor: '#2d6a4f', color: 'white', fontFamily: 'sans-serif' }}>
        <h2>Connecting to Table...</h2>
      </div>
    );
  }

  const [selectedCards, setSelectedCards] = useState([]);


// 2. Change ctx.currentPlayer to playerID
  const rawHand = G.hands[playerID] || []; 
  const myHand = sortCards(rawHand);

  
  const topDiscard = G.discardPile[G.discardPile.length - 1];
  const myMelds = G.melds[ctx.currentPlayer] || [];

  // Calculate how many Mortos are left
  const mortosAvailable = (G.pots.pot1.length > 0 ? 1 : 0) + (G.pots.pot2.length > 0 ? 1 : 0);

  // Toggle selection
  const toggleCardSelection = (cardId) => {
    if (selectedCards.includes(cardId)) {
      setSelectedCards(selectedCards.filter(id => id !== cardId));
    } else {
      setSelectedCards([...selectedCards, cardId]);
    }
  };

  // Destination Click Handlers
  const handleDiscardClick = () => {
  if (selectedCards.length === 1 && G.hasDrawn) {
      moves.discardCard(selectedCards[0]);
      setSelectedCards([]);
    } 
    // Action 2: Picking up the whole pile
    else if (selectedCards.length === 0 && !G.hasDrawn && G.discardPile.length > 0) {
      moves.pickUpDiscard();
    }
  };

  const handleNewMeldClick = () => {
    if (selectedCards.length >= 3) {
      moves.playMeld(selectedCards);
      setSelectedCards([]);
    }
  };

  const handleExistingMeldClick = (meldIndex) => {
    if (selectedCards.length > 0) {
      moves.appendToMeld(meldIndex, selectedCards);
      setSelectedCards([]);
    }
  };

  return (
    <div style={{ padding: '20px', fontFamily: 'sans-serif', backgroundColor: '#2d6a4f', minHeight: '100vh', color: 'white' }}>
      <h1>Player {ctx.currentPlayer}'s Turn</h1>
      
      <div style={{ display: 'flex', gap: '40px', marginBottom: '40px' }}>
        
        {/* Draw & Discard */}
        <div style={{ display: 'flex', gap: '20px' }}>
          <div onClick={() => moves.drawCard()} style={{ cursor: 'pointer', textAlign: 'center' }}>
            <h3>Deck ({G.deck.length})</h3>
            <div style={{ border: '2px dashed white', width: '60px', height: '90px', borderRadius: '8px', background: '#1b4332' }}></div>
          </div>

          {/* Clicking the Discard Pile executes the discard move */}
          <div onClick={handleDiscardClick}
            style={{ 
              textAlign: 'center', 
              cursor: (selectedCards.length === 1 && G.hasDrawn) || (selectedCards.length === 0 && !G.hasDrawn) ? 'pointer' : 'not-allowed' 
            }}
          >
            <h3>Discard ({G.discardPile.length})</h3>
            {topDiscard ? <Card card={topDiscard} /> : <div style={{ border: '2px dashed #40916c', width: '60px', height: '90px', borderRadius: '8px' }}></div>}
          </div>
        </div>

        {/* Melds Area */}
        <div style={{ flexGrow: 1, paddingLeft: '20px', borderLeft: '2px solid #40916c' }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', paddingRight: '20px' }}>
            <h3>Table</h3>
            <span style={{ fontSize: '1.2em', color: '#ffcc00', fontWeight: 'bold' }}>
              Mortos available: {mortosAvailable}
            </span>
          </div>
          
          <div style={{ display: 'flex', flexWrap: 'wrap', gap: '15px' }}>
            
            {/* Clickable Existing Melds */}
            {myMelds.map((meldGroup, index) => (
              <div 
                key={index} 
                onClick={() => handleExistingMeldClick(index)}
                style={{ display: 'flex', background: 'rgba(0,0,0,0.2)', padding: '5px', borderRadius: '8px', cursor: selectedCards.length > 0 ? 'pointer' : 'default' }}
              >
                {meldGroup.map(card => <Card key={card.id} card={card} />)}
              </div>
            ))}

            {/* Empty Slot to click for a New Meld */}
            <div 
              onClick={handleNewMeldClick}
              style={{ 
                border: '2px dashed #40916c', 
                borderRadius: '8px', 
                padding: '10px 20px', 
                display: 'flex', 
                alignItems: 'center',
                cursor: selectedCards.length >= 3 ? 'pointer' : 'default',
                color: selectedCards.length >= 3 ? 'white' : '#888'
              }}
            >
              + Place New Meld Here
            </div>

          </div>
        </div>
      </div>

      <hr style={{ borderColor: '#40916c', margin: '30px 0' }} />

      {/* Player's Hand */}
      <h2>My Hand</h2>
      <div style={{ display: 'flex', flexWrap: 'wrap' }}>
        {myHand.map(card => (
          <Card 
            key={card.id} 
            card={card} 
            isSelected={selectedCards.includes(card.id)}
            onClick={() => toggleCardSelection(card.id)}
          />
        ))}
      </div>
    </div>
  );
}
