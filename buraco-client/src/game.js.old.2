export const BuracoGame = {
  name: 'buraco',
  
  setup: ({ random }) => {
    // ... (keep your existing buildDeck, shuffle, and hands logic) ...

    // Give each player an empty array to hold their played melds
    return {
      deck: initialDeck,
      hands: hands,
      discardPile: discardPile,
      melds: { '0': [], '1': [], '2': [], '3': [] }, // Updated to track melds per player
      pots: pots
    };
  },

  moves: {
    drawCard: ({ G, ctx }) => {
      if (G.deck.length > 0) {
        const card = G.deck.pop();
        G.hands[ctx.currentPlayer].push(card);
      }
    },
    
    // NEW MOVE: Play a Meld
    playMeld: ({ G, ctx }, cardIds) => {
      const hand = G.hands[ctx.currentPlayer];
      
      // Find the actual card objects from the submitted IDs
      const cardsToMeld = hand.filter(card => cardIds.includes(card.id));
      
      // Basic Buraco rule: a meld must have at least 3 cards
      if (cardsToMeld.length >= 3) {
        // Remove the cards from the player's hand
        G.hands[ctx.currentPlayer] = hand.filter(card => !cardIds.includes(card.id));
        
        // Place the grouped cards onto the table
        G.melds[ctx.currentPlayer].push(cardsToMeld);
      }
    },

    // NEW MOVE: Discard and end turn
    discardCard: ({ G, ctx }, cardId) => {
      const hand = G.hands[ctx.currentPlayer];
      const cardIndex = hand.findIndex(card => card.id === cardId);
      
      if (cardIndex !== -1) {
        // Remove the single card from the hand and push it to the discard pile
        const [discardedCard] = hand.splice(cardIndex, 1);
        G.discardPile.push(discardedCard);
        
        // Discarding ends your turn in Buraco!
        ctx.events.endTurn();
      }
    }
  }
};
