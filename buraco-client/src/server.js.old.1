// FIXED: Explicitly pointing to the CommonJS server bundle
import { Server } from 'boardgame.io/dist/cjs/server.js'; 
import { BuracoGame } from './game.js';
import fs from 'fs';
import path from 'path';

const server = Server({
  games: [BuracoGame],
  origins: ['*'], // Wildcard CORS
});

// --- CUSTOM TOURNAMENT & HISTORY API ---
// Creates a local database folder on the server
const dbPath = path.join(process.cwd(), 'db');
if (!fs.existsSync(dbPath)) fs.mkdirSync(dbPath);

const tourneyFile = path.join(dbPath, 'tournaments.json');
const historyFile = path.join(dbPath, 'history.json');

// Initialize empty databases if they don't exist
if (!fs.existsSync(tourneyFile)) fs.writeFileSync(tourneyFile, '[]');
if (!fs.existsSync(historyFile)) fs.writeFileSync(historyFile, '[]');

// Read Routes
server.router.get('/api/tournaments', (ctx) => {
  ctx.body = fs.readFileSync(tourneyFile, 'utf8');
});

server.router.get('/api/history', (ctx) => {
  ctx.body = fs.readFileSync(historyFile, 'utf8');
});

// Write Routes
server.router.post('/api/tournaments', (ctx) => {
  fs.writeFileSync(tourneyFile, JSON.stringify(ctx.request.body));
  ctx.body = { success: true };
});

// Safe History Appender (Prevents duplicate saves if 4 players submit at once)
server.router.post('/api/history/add', (ctx) => {
  const newEntry = ctx.request.body;
  const history = JSON.parse(fs.readFileSync(historyFile, 'utf8'));
  
  if (!history.some(h => h.matchID === newEntry.matchID)) {
    history.unshift(newEntry);
    fs.writeFileSync(historyFile, JSON.stringify(history));
  }
  ctx.body = { success: true };
});

// Start Server
server.run({ port: 8000, host: '0.0.0.0' }, () => {
  console.log(`Server running on port 8000...`);
});
