import React, { useState, useEffect } from 'react';
import { Client } from 'boardgame.io/react';
import { SocketIO } from 'boardgame.io/multiplayer';
import { LobbyClient } from 'boardgame.io/client';
import { BuracoGame } from './game.js';
import { BuracoBoard } from './Board.jsx';

const SERVER_ADDRESS = `http://${window.location.hostname}:8000`;
const lobbyClient = new LobbyClient({ server: SERVER_ADDRESS });

const BuracoClient = Client({
  game: BuracoGame,
  board: BuracoBoard,
  multiplayer: SocketIO({ server: SERVER_ADDRESS }),
  debug: false 
});

const App = () => {
  const [view, setView] = useState('lounge'); // lounge, create, game, tournaments
  const [matches, setMatches] = useState([]);
  const [matchID, setMatchID] = useState(null);
  const [playerID, setPlayerID] = useState(null);
  const [credentials, setCredentials] = useState(null); 
  
  // NEW: Player Name State
  const [playerName, setPlayerName] = useState(() => localStorage.getItem('buraco_player_name') || '');
  
  // Rules State (Updated Defaults)
  const [rules, setRules] = useState({ numPlayers: 4, discard: 'closed', runners: 'aces_kings', largeCanasta: true, cleanCanastaToWin: true });
  const [history, setHistory] = useState([]);

  // NEW: Tournament State (Saved locally on the Host's machine)
  const [tournaments, setTournaments] = useState(() => JSON.parse(localStorage.getItem('buraco_tournaments') || '[]'));
  const [newTourney, setNewTourney] = useState({ name: '', type: 'team', players: 'João, Maria, Pedro, Ana' });

  // Auto-reconnect & Load History
  useEffect(() => {
    const session = localStorage.getItem('buraco_session');
    if (session) {
      const { matchID, playerID, credentials } = JSON.parse(session);
      setMatchID(matchID); setPlayerID(playerID); setCredentials(credentials);
      setView('game');
    }
    const savedHistory = localStorage.getItem('buraco_history');
    if (savedHistory) setHistory(JSON.parse(savedHistory));
  }, []);

  useEffect(() => {
    if (view === 'lounge' || view === 'tournaments') {
      const fetchMatches = async () => {
        try {
          const { matches } = await lobbyClient.listMatches('buraco');
          setMatches(matches);
        } catch (e) { console.error("Sem conexão com o servidor."); }
      };
      fetchMatches();
      const interval = setInterval(fetchMatches, 3000);
      return () => clearInterval(interval);
    }
  }, [view]);

  // Save Player Name
  const handleNameChange = (e) => {
    setPlayerName(e.target.value);
    localStorage.setItem('buraco_player_name', e.target.value);
  };

  const handleCreateMatch = async (customRules = rules) => {
    try {
      const createdMatch = await lobbyClient.createMatch('buraco', { numPlayers: customRules.numPlayers, setupData: customRules });
      await handleJoinMatch(createdMatch.matchID, '0');
    } catch (e) { alert("Erro ao criar mesa: " + e.message); }
  };

  const handleJoinMatch = async (id, seat) => {
    if (!playerName.trim()) {
      alert("Por favor, digite seu nome de jogador antes de entrar na mesa!");
      return;
    }
    try {
      const { playerCredentials } = await lobbyClient.joinMatch('buraco', id, { playerID: seat, playerName: playerName });
      setMatchID(id); setPlayerID(seat); setCredentials(playerCredentials); 
      localStorage.setItem('buraco_session', JSON.stringify({ matchID: id, playerID: seat, credentials: playerCredentials }));
      setView('game');
    } catch (e) { alert("Erro ao entrar no assento. Ele pode estar ocupado."); }
  };

  const handleLeaveMatch = async (finalScores = null) => {
    try {
      if (matchID && playerID && credentials) {
        await lobbyClient.leaveMatch('buraco', matchID, { playerID, credentials });
      }
    } catch (e) { console.error("Erro ao sair da mesa."); }
    
    if (finalScores) {
      const newHistory = [{ date: new Date().toLocaleString(), matchID, scores: finalScores }, ...history];
      setHistory(newHistory);
      localStorage.setItem('buraco_history', JSON.stringify(newHistory));
    }
    
    localStorage.removeItem('buraco_session');
    setView('lounge');
  };

  // --- TOURNAMENT LOGIC ---
  const handleCreateTournament = () => {
    const playerList = newTourney.players.split(',').map(p => p.trim()).filter(p => p);
    if (playerList.length % 4 !== 0) {
      alert("O número de jogadores deve ser múltiplo de 4 para gerar as mesas corretamente.");
      return;
    }
    const t = {
      id: Date.now().toString(),
      name: newTourney.name || `Torneio ${tournaments.length + 1}`,
      type: newTourney.type,
      players: playerList,
      leaderboard: playerList.reduce((acc, p) => ({ ...acc, [p]: 0 }), {}),
      rounds: []
    };
    const updated = [...tournaments, t];
    setTournaments(updated);
    localStorage.setItem('buraco_tournaments', JSON.stringify(updated));
    setNewTourney({ name: '', type: 'team', players: 'João, Maria, Pedro, Ana' });
  };

  const generateTournamentPhase = async (tIndex) => {
    const t = tournaments[tIndex];
    let shuffled = [...t.players].sort(() => Math.random() - 0.5); // Randomize players
    let matchPromises = [];
    
    // Create 1 table for every 4 players
    for (let i = 0; i < shuffled.length; i += 4) {
      matchPromises.push(lobbyClient.createMatch('buraco', { numPlayers: 4, setupData: rules }));
    }

    try {
      const createdMatches = await Promise.all(matchPromises);
      const newRound = { roundNum: t.rounds.length + 1, tables: createdMatches.map(m => m.matchID), assignments: [] };
      
      // Assign the shuffled players to the tables
      let pIndex = 0;
      for (let match of createdMatches) {
        newRound.assignments.push({
          matchID: match.matchID,
          team0: [shuffled[pIndex], shuffled[pIndex+2]],
          team1: [shuffled[pIndex+1], shuffled[pIndex+3]]
        });
        pIndex += 4;
      }

      const updated = [...tournaments];
      updated[tIndex].rounds.push(newRound);
      setTournaments(updated);
      localStorage.setItem('buraco_tournaments', JSON.stringify(updated));
      alert("Fase gerada! As mesas já estão disponíveis no Salão.");

    } catch (e) { alert("Erro ao gerar mesas do torneio: " + e.message); }
  };

  // --- VIEWS ---
  if (view === 'game') {
    return (
      <div>
        <div style={{ background: '#081c15', padding: '10px', textAlign: 'right' }}>
          <button onClick={() => handleLeaveMatch()} style={{ background: '#ff4d4d', color: 'white', border: 'none', padding: '5px 15px', borderRadius: '5px', cursor: 'pointer', fontWeight: 'bold' }}>
            Sair da Mesa
          </button>
        </div>
        <BuracoClient matchID={matchID} playerID={playerID} credentials={credentials} />
      </div>
    );
  }

  if (view === 'create') {
    return (
      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', minHeight: '100vh', backgroundColor: '#111', color: 'white', fontFamily: 'sans-serif' }}>
        <div style={{ background: '#1b4332', padding: '40px', borderRadius: '15px', border: '2px solid #4da6ff', width: '500px' }}>
          <h2 style={{ color: '#ffd700', marginTop: 0 }}>Configurar Nova Mesa Avulsa</h2>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '15px', marginBottom: '30px' }}>
            <label>Jogadores: <select value={rules.numPlayers} onChange={e => setRules({...rules, numPlayers: parseInt(e.target.value)})} style={{float:'right'}}><option value={2}>2 Jogadores</option><option value={4}>4 Jogadores</option></select></label>
            <label>Compra do Lixo: <select value={rules.discard} onChange={e => setRules({...rules, discard: e.target.value})} style={{float:'right'}}><option value="open">Aberto (Sempre)</option><option value="closed">Fechado (Obrigatório baixar)</option></select></label>
            <label>Trincas: <select value={rules.runners} onChange={e => setRules({...rules, runners: e.target.value})} style={{float:'right'}}><option value="none">Nenhuma</option><option value="aces_threes">Ás e Três</option><option value="aces_kings">Ás e Reis</option><option value="any">Qualquer Carta</option></select></label>
            <label><input type="checkbox" checked={rules.largeCanasta} onChange={e => setRules({...rules, largeCanasta: e.target.checked})} /> Bônus Canastrão (500/1000)</label>
            <label><input type="checkbox" checked={rules.cleanCanastaToWin} onChange={e => setRules({...rules, cleanCanastaToWin: e.target.checked})} /> Bater exige Canastra Limpa</label>
          </div>
          <div style={{ display: 'flex', gap: '10px' }}>
            <button onClick={() => handleCreateMatch(rules)} style={{ flex: 1, padding: '10px', background: '#ffd700', fontWeight: 'bold', cursor: 'pointer', border: 'none', borderRadius: '5px' }}>Abrir Mesa</button>
            <button onClick={() => setView('lounge')} style={{ flex: 1, padding: '10px', background: '#555', color: 'white', cursor: 'pointer', border: 'none', borderRadius: '5px' }}>Cancelar</button>
          </div>
        </div>
      </div>
    );
  }

  if (view === 'tournaments') {
    return (
      <div style={{ padding: '50px', backgroundColor: '#111', minHeight: '100vh', fontFamily: 'sans-serif', color: 'white' }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '40px', borderBottom: '2px solid #333', paddingBottom: '20px' }}>
          <h1 style={{ color: '#ffd700', margin: 0 }}>🏆 Diretor de Torneios</h1>
          <button onClick={() => setView('lounge')} style={{ padding: '10px 20px', background: '#555', color: 'white', border: 'none', borderRadius: '8px', fontWeight: 'bold', cursor: 'pointer' }}>Voltar ao Salão</button>
        </div>

        <div style={{ display: 'flex', gap: '50px', alignItems: 'flex-start' }}>
          {/* Create Tournament Form */}
          <div style={{ flex: 1, background: '#1b4332', padding: '20px', borderRadius: '10px', border: '2px solid #4da6ff' }}>
            <h2 style={{ marginTop: 0, color: '#4da6ff' }}>Criar Novo Torneio</h2>
            <div style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>
              <input type="text" placeholder="Nome do Torneio" value={newTourney.name} onChange={e => setNewTourney({...newTourney, name: e.target.value})} style={{ padding: '10px', borderRadius: '5px', border: 'none' }} />
              <select value={newTourney.type} onChange={e => setNewTourney({...newTourney, type: e.target.value})} style={{ padding: '10px', borderRadius: '5px', border: 'none' }}>
                <option value="team">Equipes Fixas</option>
                <option value="individual">Individual (Equipes Aleatórias a cada fase)</option>
              </select>
              <label style={{ fontSize: '0.9em', color: '#ccc' }}>Nomes dos Jogadores (separados por vírgula):</label>
              <textarea rows="3" value={newTourney.players} onChange={e => setNewTourney({...newTourney, players: e.target.value})} style={{ padding: '10px', borderRadius: '5px', border: 'none', resize: 'vertical' }} />
              <button onClick={handleCreateTournament} style={{ padding: '12px', background: '#ffd700', fontWeight: 'bold', border: 'none', borderRadius: '5px', cursor: 'pointer' }}>Registrar Torneio</button>
            </div>
          </div>

          {/* Active Tournaments List */}
          <div style={{ flex: 2, display: 'flex', flexDirection: 'column', gap: '20px' }}>
            {tournaments.length === 0 ? <p style={{ color: '#aaa' }}>Nenhum torneio ativo. Crie um ao lado!</p> : null}
            {tournaments.map((t, tIndex) => (
              <div key={t.id} style={{ background: 'rgba(0,0,0,0.5)', padding: '20px', borderRadius: '10px', border: '1px solid #444' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <h3 style={{ color: '#ffd700', margin: 0 }}>{t.name} <span style={{ fontSize: '0.6em', color: '#aaa' }}>({t.type === 'team' ? 'Equipes Fixas' : 'Sorteio Individual'})</span></h3>
                  <button onClick={() => generateTournamentPhase(tIndex)} style={{ background: '#4da6ff', border: 'none', padding: '8px 15px', borderRadius: '5px', color: 'white', fontWeight: 'bold', cursor: 'pointer' }}>+ Gerar Nova Fase</button>
                </div>
                
                <div style={{ display: 'flex', gap: '20px', marginTop: '20px' }}>
                  <div style={{ flex: 1 }}>
                    <h4 style={{ color: '#ccc', borderBottom: '1px solid #444', paddingBottom: '5px' }}>Placar Geral</h4>
                    {Object.entries(t.leaderboard).map(([pName, score]) => (
                      <div key={pName} style={{ display: 'flex', justifyContent: 'space-between', padding: '3px 0' }}><span>{pName}</span> <span style={{ fontWeight: 'bold', color: '#ffd700' }}>{score}</span></div>
                    ))}
                    <small style={{ color: '#888', display: 'block', marginTop: '10px' }}>*(Nota: O Anfitrião deve somar os pontos manualmente no placar geral após as mesas terminarem).*</small>
                  </div>
                  <div style={{ flex: 2 }}>
                    <h4 style={{ color: '#ccc', borderBottom: '1px solid #444', paddingBottom: '5px' }}>Fases Geradas</h4>
                    {t.rounds.map(r => (
                      <div key={r.roundNum} style={{ marginBottom: '10px', background: '#111', padding: '10px', borderRadius: '5px' }}>
                        <strong style={{ color: '#4da6ff' }}>Fase {r.roundNum}</strong>
                        {r.assignments.map((a, i) => (
                          <div key={a.matchID} style={{ fontSize: '0.9em', marginTop: '5px' }}>
                            Mesa {a.matchID.substring(0,4)}: [{a.team0.join(' & ')}] vs [{a.team1.join(' & ')}]
                          </div>
                        ))}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    );
  }

  // --- LOUNGE SCREEN ---
  return (
    <div style={{ padding: '50px', backgroundColor: '#111', minHeight: '100vh', fontFamily: 'sans-serif', color: 'white' }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '40px', borderBottom: '2px solid #333', paddingBottom: '20px' }}>
        <h1 style={{ color: '#ffd700', margin: 0 }}>♠♥ Salão de Buraco ♦♣</h1>
        
        {/* NEW: Global Player Name Input */}
        <div style={{ display: 'flex', alignItems: 'center', gap: '10px' }}>
          <label style={{ fontWeight: 'bold', color: '#4da6ff' }}>Seu Nome:</label>
          <input 
            type="text" 
            placeholder="Digite seu nome..." 
            value={playerName} 
            onChange={handleNameChange} 
            style={{ padding: '10px', borderRadius: '8px', border: '2px solid #4da6ff', background: '#222', color: 'white', fontSize: '1.1em', width: '200px' }} 
          />
        </div>

        <div style={{ display: 'flex', gap: '15px' }}>
          <button onClick={() => setView('tournaments')} style={{ padding: '15px 20px', background: '#8a2be2', color: 'white', border: 'none', borderRadius: '8px', fontSize: '1em', fontWeight: 'bold', cursor: 'pointer' }}>🏆 Torneios</button>
          <button onClick={() => setView('create')} style={{ padding: '15px 20px', background: '#4da6ff', color: 'white', border: 'none', borderRadius: '8px', fontSize: '1em', fontWeight: 'bold', cursor: 'pointer' }}>+ Mesa Avulsa</button>
        </div>
      </div>

      <div style={{ display: 'flex', gap: '50px', alignItems: 'flex-start' }}>
        
        {/* Active Tables */}
        <div style={{ flex: 2, display: 'flex', flexWrap: 'wrap', gap: '20px' }}>
          {matches.length === 0 ? <p style={{ color: '#aaa', fontSize: '1.2em' }}>Nenhuma mesa ativa no momento.</p> : null}
          {matches.map(m => {
            const isFull = m.players.every(p => p.name);
            const r = m.setupData || { numPlayers: 4, discard: 'closed', runners: 'aces_kings', cleanCanastaToWin: true };
            return (
              <div key={m.matchID} style={{ background: '#1b4332', border: '2px solid #40916c', borderRadius: '10px', padding: '20px', width: '350px' }}>
                <h3 style={{ margin: '0 0 10px 0', color: '#ffd700' }}>Mesa: {m.matchID}</h3>
                <div style={{ fontSize: '0.9em', color: '#ccc', marginBottom: '15px' }}>{r.numPlayers}P | Lixo: {r.discard === 'open' ? 'Aberto' : 'Fechado'} | Trincas: {r.runners.replace('_', ' ')}{r.cleanCanastaToWin ? " | 👑 Limpa Obrigatória" : ""}</div>
                <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                  {m.players.map(p => (
                    <div key={p.id} style={{ display: 'flex', justifyContent: 'space-between', background: 'rgba(0,0,0,0.3)', padding: '8px', borderRadius: '5px' }}>
                      <span>Assento {p.id} (Eq. {p.id % 2 === 0 ? '0' : '1'})</span>
                      {p.name ? <span style={{ color: '#aaa', fontWeight: 'bold' }}>{p.name}</span> : <button onClick={() => handleJoinMatch(m.matchID, p.id.toString())} style={{ background: '#4da6ff', border: 'none', borderRadius: '3px', color: 'white', cursor: 'pointer', padding: '2px 10px' }}>Sentar</button>}
                    </div>
                  ))}
                </div>
                {isFull && <div style={{ marginTop: '15px', color: '#ff4d4d', fontWeight: 'bold', textAlign: 'center' }}>Mesa Lotada</div>}
              </div>
            );
          })}
        </div>

        {/* Match History */}
        <div style={{ flex: 1, background: '#1b4332', padding: '20px', borderRadius: '10px', border: '2px solid #333' }}>
          <h2 style={{ color: '#ffd700', margin: '0 0 20px 0' }}>Histórico de Partidas</h2>
          {history.length === 0 ? <p style={{ color: '#aaa' }}>Nenhuma partida concluída.</p> : null}
          <div style={{ display: 'flex', flexDirection: 'column', gap: '15px', maxHeight: '600px', overflowY: 'auto' }}>
            {history.map((h, i) => (
              <div key={i} style={{ background: 'rgba(0,0,0,0.4)', padding: '10px', borderRadius: '8px' }}>
                <div style={{ fontSize: '0.8em', color: '#aaa', marginBottom: '5px' }}>{h.date} - Mesa: {h.matchID}</div>
                <div style={{ display: 'flex', justifyContent: 'space-between' }}>
                  <span style={{ color: '#4da6ff', fontWeight: 'bold' }}>Eq 0: {h.scores.team0.total}</span>
                  <span style={{ color: '#ff4d4d', fontWeight: 'bold' }}>Eq 1: {h.scores.team1.total}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  );
};

export default App;
