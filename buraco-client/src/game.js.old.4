export const BuracoGame = {
  name: 'buraco',
  setup: ({ random }) => { /* ... keep your existing setup code ... */ },

  moves: {
    drawCard: ({ G, ctx }) => { /* ... keep existing drawCard ... */ },

    playMeld: ({ G, ctx }, cardIds) => {
      const hand = G.hands[ctx.currentPlayer];
      const cardsToMeld = hand.filter(card => cardIds.includes(card.id));
      
      if (isValidMeld(cardsToMeld)) {
        G.hands[ctx.currentPlayer] = hand.filter(card => !cardIds.includes(card.id));
        G.melds[ctx.currentPlayer].push(sortCards(cardsToMeld));
      } else {
        return; // Safely reject the move by doing nothing
      }
    },

    appendToMeld: ({ G, ctx }, meldIndex, cardIds) => {
      const hand = G.hands[ctx.currentPlayer];
      const cardsToAdd = hand.filter(card => cardIds.includes(card.id));
      const existingMeld = G.melds[ctx.currentPlayer][meldIndex];
      const proposedMeld = [...existingMeld, ...cardsToAdd];
      
      if (isValidMeld(proposedMeld)) {
        G.hands[ctx.currentPlayer] = hand.filter(card => !cardIds.includes(card.id));
        G.melds[ctx.currentPlayer][meldIndex] = sortCards(proposedMeld);
      } else {
        return; // Safely reject the move by doing nothing
      }
    },


